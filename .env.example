# Copy to .env (gitignored) and fill in only what you use. Nothing here is
# required — agi-layer runs offline out of the box.

# --- Claude via API key (optional) ---
# The DEFAULT Claude path uses your Pro/Max subscription via `claude login`
# (no key needed). Set this only if you want the pay-per-token API path instead.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- Interface: cli (default) | api | mcp ---
AGI_INTERFACE=cli

# --- Logging: DEBUG | INFO | WARNING (default) | ERROR ---
AGI_LOG_LEVEL=WARNING

# --- Show technical error detail in the CLI (any value = on) ---
# AGI_DEBUG=1
